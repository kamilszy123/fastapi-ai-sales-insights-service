APP_NAME="AI Sales Insights API"

POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=ai_sales_insights_db

# If you change the PostgreSQL settings above,
# update DATABASE_URL and ALEMBIC_DATABASE_URL accordingly.

DATABASE_URL=postgresql://postgres_user:postgres_password@db:5432/ai_sales_insights_db
ALEMBIC_DATABASE_URL=postgresql://postgres_user:postgres_password@localhost:5433/ai_sales_insights_db
MCP_DATABASE_URL=postgresql://postgres_user:postgres_password@localhost:5433/ai_sales_insights_db


SECRET_KEY=your-secret-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=your-openai-api-key

OPENAI_MODEL=gpt-4.1-nano
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=3

MCP_USER_ID=1